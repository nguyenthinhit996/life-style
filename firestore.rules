rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public collections — anyone can read, no one can write from client
    match /series/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /chapters/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /posts/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /about/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Users & everything else — no client access at all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
