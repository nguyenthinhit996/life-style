rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read-only collections
    match /series/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /chapters/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /posts/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /about/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Users collection — no client access (server-side only via Admin SDK or API routes)
    match /users/{id} {
      allow read, write: if false;
    }
  }
}
